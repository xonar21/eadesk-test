generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScenarioRun {
  id        String   @id @default(cuid())
  type      String
  status    String
  duration  Int?
  error     String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("scenario_runs")
}
